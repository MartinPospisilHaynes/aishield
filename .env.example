# ============================================
# AIshield.cz — Environment Variables
# ============================================
# ⚠️ TENTO SOUBOR NIKDY NESMÍ BÝT V GITU!
# Zkopíruj do .env a vyplň skutečné hodnoty.
# ============================================

# ── Supabase ──
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Claude API (Anthropic) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── GoPay ──
GOPAY_GO_ID=
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=
GOPAY_IS_PRODUCTION=false

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ── Comgate ──
COMGATE_MERCHANT_ID=
COMGATE_SECRET=
COMGATE_IS_PRODUCTION=false

# ── Výchozí platební brána ──
DEFAULT_PAYMENT_GATEWAY=gopay

# ── Resend (Email) ──
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=info@aishield.cz

# ── App Config ──
APP_URL=https://aishield.cz
API_URL=https://api.aishield.cz
ENVIRONMENT=development

# ── VPS (Lovec Robot) ──
VPS_HOST=46.28.110.102
VPS_USER=root

# Šifrovací klíč pro export dat (Fernet AES-128) — vygeneruj: python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
DATA_EXPORT_KEY=
