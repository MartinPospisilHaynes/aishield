"""
AIshield.cz — ARES API klient v2 (POST-based)
Hledání firem v Administrativním registru ekonomických subjektů.
ARES V3 REST API vyžaduje POST, ne GET.

Strategie:
  1. Hledání podle obchodního jména (wildcard)
  2. Hledání podle CZ-NACE (5-ciferné kódy)
  3. Lookup jednotlivé firmy podle IČO
"""

import httpx
import asyncio
from dataclasses import dataclass
from typing import Optional

# ARES REST API V3
ARES_BASE_URL = "https://ares.gov.cz/ekonomicke-subjekty-v-be/rest"
ARES_SEARCH_URL = f"{ARES_BASE_URL}/ekonomicke-subjekty/vyhledat"
ARES_DETAIL_URL = f"{ARES_BASE_URL}/ekonomicke-subjekty"

# CZ-NACE kódy (5-ciferné!) — relevantní pro AI Act
RELEVANT_NACE = [
    "47910",   # Maloobchod prostřednictvím internetu (e-shopy)
    "47990",   # Ostatní maloobchod mimo prodejny
    "62010",   # Programování
    "62020",   # Poradenství v oblasti IT
    "62090",   # Ostatní činnosti v oblasti IT
    "63110",   # Zpracování dat, hosting
    "63120",   # Webové portály
    "63990",   # Ostatní informační činnosti
    "73110",   # Reklamní agentury
    "70210",   # PR a komunikace
    "69100",   # Právní činnosti
    "69200",   # Účetnictví a audit
    "65110",   # Životní pojištění
    "65120",   # Neživotní pojištění
    "64190",   # Ostatní peněžní zprostředkování
    "85590",   # Ostatní vzdělávání (e-learning)
    "46900",   # Nespecializovaný velkoobchod
    "47110",   # Maloobchod se smíšeným zbožím
    "47190",   # Ostatní maloobchod
    "58210",   # Vydávání počítačových her
    "58290",   # Vydávání ostatního software
    "61100",   # Telekomunikační činnosti
]

# Klíčová slova pro hledání firem podle jména
SEARCH_KEYWORDS = [
    "digital", "software", "IT", "web", "tech", "data",
    "marketing", "media", "cloud", "hosting", "e-shop",
    "eshop", "online", "internet", "agency", "agentura",
    "poradenství", "consulting", "solutions", "systems",
    "systémy", "automatizace", "analytik", "logistik",
]


@dataclass
class AresCompany:
    """Firma nalezená v ARES."""
    ico: str
    name: str
    legal_form: str
    nace: list[str]
    address: str
    region: str


def _parse_company(item: dict) -> AresCompany:
    """Parsuje firmu z ARES JSON odpovědi."""
    sidlo = item.get("sidlo", {})
    address_parts = []
    if sidlo.get("nazevUlice"):
        cd = sidlo.get("cisloDomovni", "")
        co = sidlo.get("cisloOrientacni", "")
        street = sidlo["nazevUlice"]
        if cd:
            street += f" {cd}"
        if co:
            street += f"/{co}"
        address_parts.append(street)
    if sidlo.get("nazevCastiObce") and sidlo.get("nazevCastiObce") != sidlo.get("nazevObce"):
        address_parts.append(sidlo["nazevCastiObce"])
    if sidlo.get("psc"):
        address_parts.append(str(sidlo["psc"]))
    if sidlo.get("nazevObce"):
        address_parts.append(sidlo["nazevObce"])

    pf = item.get("pravniForma", "")
    if isinstance(pf, dict):
        pf = pf.get("nazev", str(pf.get("kod", "")))

    nace_list = item.get("czNace", []) or item.get("czNace2008", []) or []

    return AresCompany(
        ico=item.get("ico", ""),
        name=item.get("obchodniJmeno", ""),
        legal_form=str(pf),
        nace=nace_list if isinstance(nace_list, list) else [nace_list],
        address=", ".join(address_parts),
        region=sidlo.get("nazevObce", ""),
    )


async def _post_search(payload: dict) -> dict:
    """Provede POST vyhledávání v ARES."""
    try:
        async with httpx.AsyncClient(timeout=30.0) as client:
            response = await client.post(
                ARES_SEARCH_URL,
                json=payload,
                headers={
                    "Content-Type": "application/json",
                    "Accept": "application/json",
                },
            )
            response.raise_for_status()
            return response.json()
    except Exception as e:
        print(f"[ARES] Chyba POST: {e}")
        return {"pocetCelkem": 0, "ekonomickeSubjekty": []}


async def search_by_name(
    keyword: str,
    start: int = 0,
    count: int = 100,
) -> list[AresCompany]:
    """
    Vyhledá firmy podle obchodního jména (wildcard match).
    Nejspolehlivější metoda — ARES hledá přes fulltext.
    """
    payload = {
        "obchodniJmeno": keyword,
        "start": start,
        "pocet": min(count, 1000),
    }

    data = await _post_search(payload)
    companies = []
    for item in data.get("ekonomickeSubjekty", []):
        if not item.get("ico"):
            continue
        companies.append(_parse_company(item))

    print(f"[ARES] Jméno '{keyword}': {len(companies)} firem (celkem {data.get('pocetCelkem', 0)})")
    return companies


async def search_by_nace(
    nace_code: str,
    start: int = 0,
    count: int = 100,
) -> list[AresCompany]:
    """
    Vyhledá firmy podle CZ-NACE kódu (5-ciferný!).
    Pozor: ARES V3 vrací omezený počet výsledků pro NACE.
    """
    payload = {
        "czNace": [nace_code],
        "start": start,
        "pocet": min(count, 1000),
    }

    data = await _post_search(payload)
    companies = []
    for item in data.get("ekonomickeSubjekty", []):
        if not item.get("ico"):
            continue
        companies.append(_parse_company(item))

    print(f"[ARES] NACE {nace_code}: {len(companies)} firem (celkem {data.get('pocetCelkem', 0)})")
    return companies


# Zachování zpětné kompatibility
async def search_ares_by_nace(
    nace_code: str,
    region: str = "",
    start: int = 0,
    count: int = 100,
) -> list[AresCompany]:
    """Zpětně kompatibilní wrapper — používá nové POST API."""
    # Převod 4-ciferného kódu na 5-ciferný
    if len(nace_code) == 4:
        nace_code = nace_code + "0"
    return await search_by_nace(nace_code, start, count)


async def search_ares_company(ico: str) -> Optional[AresCompany]:
    """Načte detail jedné firmy podle IČO."""
    # Doplň na 8 číslic
    ico = ico.zfill(8)
    try:
        async with httpx.AsyncClient(timeout=15.0) as client:
            response = await client.get(
                f"{ARES_DETAIL_URL}/{ico}",
                headers={"Accept": "application/json"},
            )
            response.raise_for_status()
            item = response.json()
    except Exception as e:
        print(f"[ARES] Chyba detail IČO {ico}: {e}")
        return None

    return _parse_company(item)


async def batch_search(
    nace_codes: list[str] | None = None,
    max_per_nace: int = 100,
) -> list[AresCompany]:
    """
    Prohledá ARES pro relevantní NACE kódy + klíčová slova.
    Kombinuje oba přístupy pro maximální záběr.
    Deduplikuje podle IČO.
    """
    all_companies: dict[str, AresCompany] = {}

    # 1. Klíčová slova (hlavní zdroj — spolehlivější)
    for keyword in SEARCH_KEYWORDS:
        print(f"[ARES] Hledám '{keyword}'...")
        companies = await search_by_name(keyword, count=max_per_nace)
        for c in companies:
            if c.ico not in all_companies:
                all_companies[c.ico] = c

        # Rate limit
        await asyncio.sleep(0.5)

    # 2. NACE kódy (doplňkový zdroj)
    codes = nace_codes or RELEVANT_NACE[:10]
    for code in codes:
        # Převod 4→5 číslic
        if len(code) == 4:
            code = code + "0"
        print(f"[ARES] Hledám NACE {code}...")
        companies = await search_by_nace(code, count=max_per_nace)
        for c in companies:
            if c.ico not in all_companies:
                all_companies[c.ico] = c
            else:
                # Přidej NACE kód
                existing = all_companies[c.ico]
                for nc in c.nace:
                    if nc not in existing.nace:
                        existing.nace.append(nc)

        await asyncio.sleep(0.5)

    result = list(all_companies.values())
    print(f"[ARES] Celkem nalezeno: {len(result)} unikátních firem")
    return result


async def search_by_region(
    region_name: str,
    keywords: list[str] | None = None,
    max_results: int = 200,
) -> list[AresCompany]:
    """
    Najde firmy v konkrétním regionu/městě.
    Hledá přes klíčová slova a filtruje podle města.
    Užitečné pro cílený outreach (např. Olomoucko).
    """
    search_terms = keywords or SEARCH_KEYWORDS[:10]
    all_companies: dict[str, AresCompany] = {}

    for keyword in search_terms:
        companies = await search_by_name(keyword, count=200)
        for c in companies:
            if region_name.lower() in c.region.lower():
                if c.ico not in all_companies:
                    all_companies[c.ico] = c

        await asyncio.sleep(0.5)

        if len(all_companies) >= max_results:
            break

    result = list(all_companies.values())
    print(f"[ARES] Region '{region_name}': {len(result)} firem")
    return result
